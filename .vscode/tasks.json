{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build raylib",
            "type": "shell",
            "command": "g++",
            "args": [
                "*.cpp",
                "-Iinclude",
                "-Llib",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-std=c++17",
                "-o",
                "app.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "run raylib",
            "type": "shell",
            "command": "./app.exe",
            "dependsOn": "build raylib"
        }
    ]
}
